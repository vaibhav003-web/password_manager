def decrypt():                                      #decryption function

    with open("key","rb") as f:
        key=f.read()

    cipher = Fernet(key)

    #read encrypted vault
    with open("lock","rb") as f:
        encrypted = f.read()

    #decrypt
    decrypted = cipher.decrypt(encrypted)

    #convert JSON back to dictionary
    return json.loads(decrypted.decode())

def encrypt(vault):                                 #encryption function

    cipher = Fernet(key)
    data = json.dumps(vault) #convert vault to JSON text
    encrypted = cipher.encrypt(data.encode()) #encrypt data
    with open("lock", "wb") as file:     #save encrypt vault
        file.write(encrypted)
        return 0

